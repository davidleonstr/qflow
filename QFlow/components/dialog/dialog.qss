/* Styles for './dialog.py' on './properties.py' */

/* When Dialog it's white */
#white-floatingDialog {
    background-color: rgb(255, 255, 255);
    border-radius: 10px;
    padding: 15px;
}

/* When Dialog it's black */
#black-floatingDialog {
    background-color: rgb(34, 34, 34);
    border-radius: 10px;
    padding: 15px;
}